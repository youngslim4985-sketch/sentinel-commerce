rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: brands
    // Document ID: brandId (string)
    // Fields:
    //   - id: string (required)
    //   - name: string (required, size < 100)
    //   - profit: number (required)
    //   - burn: number (required)
    //   - velocity: number (required, 0-1)
    //   - status: string (required, enum: ACTIVE, INCUBATING, PAUSED)
    //   - orders: int (required)
    //   - ownerId: string (required, immutable)
    //
    // Collection: events
    // Document ID: eventId (string)
    // Fields:
    //   - agent: string (required)
    //   - type: string (required)
    //   - payload: map (required)
    //   - timestamp: string (required, ISO 8601)
    //   - ownerId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "youngslim4985@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidBrand(data) {
      return data.keys().hasAll(['id', 'name', 'profit', 'burn', 'velocity', 'status', 'orders', 'ownerId']) &&
             data.keys().hasOnly(['id', 'name', 'profit', 'burn', 'velocity', 'status', 'orders', 'ownerId']) &&
             data.id is string &&
             data.name is string && data.name.size() < 100 &&
             data.profit is number &&
             data.burn is number &&
             data.velocity is number && data.velocity >= 0 && data.velocity <= 1 &&
             data.status in ['ACTIVE', 'INCUBATING', 'PAUSED'] &&
             data.orders is int &&
             data.ownerId is string;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['agent', 'type', 'payload', 'timestamp', 'ownerId']) &&
             data.keys().hasOnly(['agent', 'type', 'payload', 'timestamp', 'ownerId']) &&
             data.agent is string &&
             data.type is string &&
             data.payload is map &&
             data.timestamp is string &&
             data.ownerId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /brands/{brandId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidBrand(request.resource.data) && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if isDocOwner() && isValidBrand(request.resource.data) && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /events/{eventId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidEvent(request.resource.data) && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      allow update: if false; // Events are immutable logs
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
